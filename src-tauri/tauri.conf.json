{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "HaruCloud Sync",
  "version": "0.1.0-beta.2",
  "identifier": "org.harukoto.harucloud.sync",
  "build": {
    "frontendDist": "../ui",
    "beforeDevCommand": "echo",
    "beforeBuildCommand": "echo"
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU2NDJDM0QzRDlBQTBCMkMKUldRc0M2clowOE5DVnMzbEV3cmp4bGs3UlJ4NWNhZWYxbnRjL3N5UkYyLzhuYUVDNkpNUWxYNWIK",
      "endpoints": [
        "https://github.com/Harukoto-Project/HaruCloud/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "HaruCloud Sync (Beta)",
        "width": 800,
        "height": 600,
        "minWidth": 320,
        "minHeight": 400,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis"],
    "publisher": "Harukoto",
    "copyright": "Copyright © 2023-2026 Harukoto Project",
    "shortDescription": "ローカルフォルダを MinIO（S3）へ同期",
    "category": "Utility",
    "license": "MIT",
    "licenseFile": "../LICENSE",
    "icon": [
      "icons/HaruCloud.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["Japanese", "English"],
        "installerIcon": "icons/HaruCloud.ico"
      }
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
