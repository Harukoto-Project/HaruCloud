{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "HaruCloud Sync",
  "version": "0.1.0",
  "identifier": "jp.harukoto.harucloud.sync",
  "build": {
    "frontendDist": "../ui",
    "beforeDevCommand": "echo",
    "beforeBuildCommand": "echo"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "HaruCloud Sync",
        "width": 800,
        "height": 600,
        "minWidth": 320,
        "minHeight": 400,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "Harukoto",
    "copyright": "Copyright © 2026 Harukoto",
    "shortDescription": "ローカルフォルダを MinIO（S3）へ同期",
    "category": "Utility",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["Japanese", "English"],
        "installerIcon": "icons/icon.ico"
      }
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
